{
  "expo": {
    "name": "Nothing",
    "slug": "nothing",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nothing",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.levanton.nothing",
      "appleTeamId": "45DBHDBF45",
      "icon": "./assets/Icon.icon"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.levanton.nothing"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#C26749",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#C26749"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "45DBHDBF45",
          "appGroup": "group.com.levanton.nothing"
        }
      ],
      "expo-asset",
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "revenueCatIosKey": ""
    }
  }
}
