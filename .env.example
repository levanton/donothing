# Copy to `.env` and fill in. Both files are loaded by Expo at build
# time; `.env` is gitignored, `.env.example` is committed as a template.

# Sentry DSN — required for crash reporting in production. Without it
# both initSentry() and captureError() no-op silently.
EXPO_PUBLIC_SENTRY_DSN=

# PostHog product analytics. The project key is a write-only public token
# (safe in the app bundle). Without it, analytics no-ops silently.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
